# Copy this file to .env and fill in your real values.
# Never commit your real .env file to GitHub.

# Option A: If your host gives you one connection string, use this:
# DATABASE_URL=mysql://user:password@host:port/database_name

# Option B: If your host gives you separate values, use these instead:
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=process.env.DB_PASSWORD,
DB_NAME=railway

# Port your app runs on (Railway sets this automatically, safe to leave as-is)
PORT=3000

# A secret password YOU choose, used to view submissions at /api/submissions?key=...
ADMIN_KEY=choose-a-strong-secret-here
